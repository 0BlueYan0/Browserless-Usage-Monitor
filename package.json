{
  "name": "browserless-usage-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Pages + Workers dashboard / PWA to monitor browserless.io token usage, quota and estimated days remaining",
  "scripts": {
    "dev": "wrangler pages dev -- npm run dev:vite",
    "dev:vite": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/gen-icons.mjs",
    "secrets:gen": "node scripts/gen-secrets.mjs",
    "db:create": "wrangler d1 create browserless-monitor",
    "db:migrate:local": "wrangler d1 migrations apply browserless-monitor --local",
    "db:migrate:remote": "wrangler d1 migrations apply browserless-monitor --remote",
    "worker:dev": "wrangler dev -c worker/wrangler.toml --test-scheduled",
    "worker:deploy": "wrangler deploy -c worker/wrangler.toml"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "hono": "^4.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.2",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8",
    "wrangler": "^4.20.0"
  }
}
